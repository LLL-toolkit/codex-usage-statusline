+fn format_reset_duration(reset_at: DateTime<Local>, captured_at: DateTime<Local>) -> String {
+    let total_minutes = (reset_at - captured_at).num_minutes().max(0);
+    let days = total_minutes / (24 * 60);
+    let hours = (total_minutes % (24 * 60)) / 60;
+    let minutes = total_minutes % 60;
+
+    if days > 0 {
+        format!("{days}d {hours}h")
+    } else if hours > 0 {
+        format!("{hours}h {minutes}m")
+    } else {
+        format!("{minutes}m")
+    }
+}

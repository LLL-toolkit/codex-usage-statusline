+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub(super) enum StatusLineLabel {
+    Context,
+    Usage,
+    Weekly,
+    Reset,
+}
+
+pub(super) fn status_line_label(label: StatusLineLabel) -> &'static str {
+    let language = std::env::var("CODEX_USAGE_STATUSLINE_LANGUAGE").ok();
+    status_line_label_for_language(language.as_deref(), label)
+}
+
+pub(super) fn status_line_label_for_language(
+    language: Option<&str>,
+    label: StatusLineLabel,
+) -> &'static str {
+    match (language, label) {
+        (Some("en"), StatusLineLabel::Context) => "Context",
+        (Some("en"), StatusLineLabel::Usage) => "Usage",
+        (Some("en"), StatusLineLabel::Weekly) => "Weekly",
+        (Some("en"), StatusLineLabel::Reset) => "resets in",
+        (Some("ja"), StatusLineLabel::Context) => "コンテキスト",
+        (Some("ja"), StatusLineLabel::Usage) => "使用量",
+        (Some("ja"), StatusLineLabel::Weekly) => "週間",
+        (Some("ja"), StatusLineLabel::Reset) => "リセットまで",
+        (_, StatusLineLabel::Context) => "컨텍스트",
+        (_, StatusLineLabel::Usage) => "사용량",
+        (_, StatusLineLabel::Weekly) => "주간",
+        (_, StatusLineLabel::Reset) => "초기화까지",
+    }
+}

+pub(super) fn status_line_progress_bar(percent: f64) -> String {
+    const SEGMENTS: usize = 10;
+    let filled = ((percent.clamp(0.0, 100.0) / 100.0) * SEGMENTS as f64).round() as usize;
+    format!("{}{}", "█".repeat(filled), "░".repeat(SEGMENTS - filled))

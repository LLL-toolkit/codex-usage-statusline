+fn usage_status_style(item: StatusLineItem, text: &str) -> Option<Style> {
+    if !matches!(
+        item,
+        StatusLineItem::ContextUsed | StatusLineItem::FiveHourLimit | StatusLineItem::WeeklyLimit
+    ) {
+        return None;
+    }
+
+    let percent = text
+        .split_whitespace()
+        .find_map(|part| part.strip_suffix('%'))?
+        .parse::<f64>()
+        .ok()?;
+    let color = if percent >= 85.0 {
+        Color::Red
+    } else if percent >= 60.0 {
+        Color::Yellow
+    } else {
+        Color::Rgb(196, 181, 253)
+    };
+    Some(Style::default().fg(color))
+}
